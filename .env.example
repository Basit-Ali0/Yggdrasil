# Supabase (from Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini (from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true

# Connector credential encryption (P2, 32-byte key as 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# YGG_CONNECTOR_SECRET=

# Playwright (`npm run test:e2e`): if unset, playwright.config.ts supplies placeholder
# Supabase/Gemini values so the dev server can boot for smoke tests only.
